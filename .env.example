# ==============================================================================
# ENVIRONMENT VARIABLES - INVENTORY & ORDER MANAGEMENT SYSTEM
# ==============================================================================

# --- DATABASE CONFIGURATION ---
# Local SQLite fallback URL: sqlite:///./inventory.db
# Local Docker Compose PostgreSQL URL: postgresql://postgres:postgres_secure_pass@db:5432/inventory_db
# Production Render URL: postgresql://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql://postgres:postgres_secure_pass@db:5432/inventory_db

# --- FRONTEND CLIENT CONFIGURATION ---
# Local development API endpoint: http://localhost:8000
# Production API endpoint (Render): https://your-backend.onrender.com
VITE_API_URL=http://localhost:8000
